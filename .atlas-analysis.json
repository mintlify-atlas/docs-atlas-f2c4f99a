  "keyFeatures": [
    "Scans unstaged git changes or branch diffs to understand what to test",
    "AI-generated test plans using Claude Code or Codex CLI",
    "Interactive TUI for reviewing and approving test plans before execution",
    "Real browser execution via Playwright with session recording (rrweb)",
    "Automatic cookie/auth injection from Chrome, Firefox, and Safari profiles",
    "Headless CI mode with GitHub Actions integration",
    "Adversarial testing approach — tries to break features, not just confirm they render",
    "Agent skill integration for Claude Code, Codex, and Cursor"
  ],
  "publicApiSurface": [
    "expect-cli (bin command)",
    "expect-cli init",
    "expect-cli add github-action",
    "expect-cli add skill",
    "expect-cli audit",
    "-m / --message <instruction>",
    "-f / --flow <slug>",
    "-y / --yes",
    "-a / --agent <claude|codex>",
    "-t / --target <unstaged|branch|changes>",
    "--headed",
    "--no-cookies",
    "--ci",
    "--timeout <ms>",
    "--verbose",
    "createPage() — @expect/browser",
    "snapshot() — @expect/browser",
    "act() — @expect/browser",
    "injectCookies() — @expect/browser",
    "extractCookies() — @expect/cookies",
    "detectBrowserProfiles() — @expect/cookies",
    "extractProfileCookies() — @expect/cookies",
    "matchCookieHeader() — @expect/cookies",
    "toPlaywrightCookies() — @expect/cookies",
    "toPuppeteerCookies() — @expect/cookies",
    "createClaudeModel() — @expect/agent",
    "createCodexModel() — @expect/agent"
  ]
}
